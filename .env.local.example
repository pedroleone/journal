# Local development environment
# Copy this to .env.local and fill in the values that don't have defaults.

# Auth
NEXT_PUBLIC_PBKDF2_SALT=<generate with: openssl rand -base64 16>
SESSION_SECRET=<generate with: openssl rand -hex 32>
AUTH_SECRET=<generate with: openssl rand -base64 32>
SERVER_ENCRYPTION_SECRET=<generate with: openssl rand -hex 32>

# Database — local SQLite file, no auth token needed
TURSO_DATABASE_URL=file:local.db

# S3 (MinIO via docker-compose)
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY=localkey
R2_SECRET_KEY=localsecret
R2_BUCKET=journal
R2_FORCE_PATH_STYLE=true
