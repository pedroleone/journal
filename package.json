{
  "name": "journal",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "local:up": "docker compose up -d",
    "local:down": "docker compose down",
    "local:setup": "bash scripts/setup-local.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --experimental-strip-types scripts/run-drizzle.ts migrate",
    "db:push": "node --experimental-strip-types scripts/run-drizzle.ts push",
    "db:push:prod": "dotenv -e .env -- node --experimental-strip-types scripts/run-drizzle.ts push",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1003.0",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/view": "^6.39.16",
    "@lezer/highlight": "^1.2.3",
    "@libsql/client": "^0.17.0",
    "@uiw/react-codemirror": "^4.25.8",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.2.0",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "next-auth": "5.0.0-beta.30",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
